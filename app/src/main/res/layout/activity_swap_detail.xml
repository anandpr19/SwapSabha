<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/stitch_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Status chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="PENDING"
            app:chipMinHeight="36dp"
            app:textStartPadding="16dp"
            app:textEndPadding="16dp"
            android:textColor="@color/stitch_primary"
            app:chipBackgroundColor="@color/stitch_surface_container_highest"
            app:chipStrokeWidth="0dp" />

        <!-- Skill name -->
        <TextView
            android:id="@+id/tvSkillName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Skill Name"
            android:fontFamily="sans-serif-black"
            android:textSize="28sp"
            android:textColor="@color/stitch_on_surface"
            android:gravity="center" />

        <!-- Participants Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/stitch_surface_container"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_requester"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:textColor="@color/stitch_on_surface_variant" />

                <TextView
                    android:id="@+id/tvRequesterName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requester"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="18sp"
                    android:textColor="@color/stitch_on_surface" />

                <!-- Ghost Divider rather than strict line -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/stitch_surface_container_highest" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_teacher"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:textColor="@color/stitch_on_surface_variant" />

                <TextView
                    android:id="@+id/tvTeacherName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Teacher"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="18sp"
                    android:textColor="@color/stitch_on_surface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Details Bento Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/stitch_surface_container"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_date_time"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:textColor="@color/stitch_on_surface_variant" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp"
                    android:textColor="@color/stitch_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_duration"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:textColor="@color/stitch_on_surface_variant" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 min"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp"
                    android:textColor="@color/stitch_on_surface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_location"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="12sp"
                    android:textColor="@color/stitch_on_surface_variant" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="16sp"
                    android:textColor="@color/stitch_on_surface" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Message -->
        <TextView
            android:id="@+id/tvMessageLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="8dp"
            android:text="@string/label_message"
            android:fontFamily="sans-serif-bold"
            android:textSize="16sp"
            android:textColor="@color/stitch_on_surface"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:text=""
            android:fontFamily="sans-serif-medium"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/stitch_on_surface_variant"
            android:visibility="gone" />

        <!-- Action buttons -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_accept"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/stitch_on_surface"
                app:backgroundTint="@color/stitch_primary"
                app:cornerRadius="32dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.UnelevatedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_complete"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/stitch_on_surface"
                app:backgroundTint="@color/stitch_secondary"
                app:cornerRadius="32dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.UnelevatedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_reject"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="@color/stitch_on_surface_variant"
                app:backgroundTint="@android:color/transparent"
                app:strokeColor="@color/stitch_surface_container_highest"
                app:strokeWidth="1dp"
                app:cornerRadius="32dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_cancel_swap"
                android:textSize="18sp"
                android:fontFamily="sans-serif-bold"
                android:textColor="#ff716c"
                app:backgroundTint="@color/stitch_surface_container"
                app:cornerRadius="32dp"
                android:visibility="gone"
                style="@style/Widget.Material3.Button.UnelevatedButton" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/stitch_primary"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
