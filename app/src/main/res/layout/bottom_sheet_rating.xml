<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bottom_sheet_bento_bg">

    <View
        android:layout_width="48dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="#484848" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_rate_swap"
        android:fontFamily="sans-serif-black"
        android:textSize="24sp"
        android:textColor="@color/stitch_on_surface"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvRateUser"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="How was your experience?"
        android:fontFamily="sans-serif-medium"
        android:textSize="16sp"
        android:textColor="@color/stitch_on_surface_variant"
        android:gravity="center" />

    <!-- Star Rating -->
    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:numStars="5"
        android:stepSize="1"
        android:rating="5"
        android:progressTint="@color/stitch_secondary"
        android:progressBackgroundTint="@color/stitch_surface_container_highest"
        style="?android:attr/ratingBarStyleIndicator"
        android:isIndicator="false" />

    <!-- Positive Tags -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/label_tags"
        android:fontFamily="sans-serif-bold"
        android:textSize="18sp"
        android:textColor="@color/stitch_on_surface" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chipGroupTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:chipSpacingVertical="12dp"
        app:chipSpacingHorizontal="12dp"
        app:singleSelection="false" />

    <!-- Comment Bento Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilComment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="@string/hint_comment"
        app:counterEnabled="true"
        app:counterMaxLength="500"
        app:counterTextColor="@color/stitch_on_surface_variant"
        app:boxBackgroundColor="@color/stitch_surface_container"
        app:boxCornerRadiusTopStart="24dp"
        app:boxCornerRadiusTopEnd="24dp"
        app:boxCornerRadiusBottomStart="24dp"
        app:boxCornerRadiusBottomEnd="24dp"
        app:boxStrokeWidth="0dp"
        app:boxStrokeWidthFocused="0dp"
        app:hintTextColor="@color/stitch_primary"
        style="@style/Widget.Material3.TextInputLayout.FilledBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:maxLength="500"
            android:minLines="3"
            android:textColor="@color/stitch_on_surface"
            android:fontFamily="sans-serif" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Submit -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitRating"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_submit_rating"
        android:textSize="18sp"
        android:fontFamily="sans-serif-bold"
        android:textColor="@color/stitch_on_surface"
        app:backgroundTint="@color/stitch_primary"
        app:cornerRadius="32dp"
        style="@style/Widget.Material3.Button.UnelevatedButton" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/stitch_primary"
        android:visibility="gone" />

</LinearLayout>
