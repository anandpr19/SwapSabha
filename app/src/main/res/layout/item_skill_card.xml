<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="24dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/stitch_surface_container"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image Placeholder (Can act as hero background for Tinder cards) -->
        <ImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:contentDescription="User avatar"
            android:scaleType="centerCrop"
            android:background="@color/stitch_surface_container_highest" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvSkillName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skill Name"
                android:fontFamily="sans-serif-bold"
                android:textSize="22sp"
                android:textColor="@color/stitch_on_surface" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:textSize="16sp"
                android:textColor="@color/stitch_on_surface_variant" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.chip.Chip
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    app:chipMinHeight="32dp"
                    app:textStartPadding="12dp"
                    app:textEndPadding="12dp"
                    android:textColor="@color/stitch_secondary"
                    app:chipBackgroundColor="@color/stitch_surface_container_highest"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/tvLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Level"
                    app:chipMinHeight="32dp"
                    app:textStartPadding="12dp"
                    app:textEndPadding="12dp"
                    android:textColor="@color/stitch_primary"
                    app:chipBackgroundColor="@color/stitch_surface_container_highest"
                    app:chipStrokeWidth="0dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
